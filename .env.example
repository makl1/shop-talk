# Copy this to .env on the Lightsail instance and fill in real values.
# Never commit .env to git.

# Qdrant (leave as-is for Docker Compose networking)
QDRANT_URL=http://qdrant:6333
COLLECTION_NAME=products_clip

# CLIP model
CLIP_MODEL=openai/clip-vit-base-patch32

# Multimodal blend ratio: 0 = image only, 1 = text only
ALPHA=0.5

# AWS S3 — image storage
S3_BUCKET=shoptalk-assistant
AWS_REGION=us-west-2
SIGNED_URL_TTL=900

# AWS credentials (IAM user with s3:GetObject on the bucket above)
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY_HERE

# Data pipeline tuning (used by indexing scripts, not the API)
LIMIT=5000
BATCH=64
